# Set to "production" in the real deployment -- with SECRET_KEY still at its
# default, ENVIRONMENT=production refuses to start at all (session forgery
# risk); anywhere else it's just a startup warning, so local dev/CI don't
# need a real key.
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://migratepro:migratepro@localhost:5432/migratepro
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]
ANTHROPIC_API_KEY=

# Optional -- without these, reminder/overdue emails are logged instead of sent
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=no-reply@migratepro.local

# Used only to seed the first admin login (app/seed_admin.py); change the
# password after first sign-in
SEED_ADMIN_EMAIL=admin@migratepro.local
SEED_ADMIN_PASSWORD=changeme123
